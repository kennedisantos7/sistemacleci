# ==========================================================================
# Site público (apps/site) — copie para apps/site/.env.local em dev
# ==========================================================================

# URL do sistema (back-end) que recebe a ingestão de vendas/checkout.
SISTEMA_URL="http://localhost:3001"

# Chave compartilhada para autenticar o POST /api/sales/ingest.
# DEVE ser idêntica à INGEST_API_KEY do sistema. NUNCA prefixe com NEXT_PUBLIC_
# (é usada apenas no servidor, na route /api/checkout).
INGEST_API_KEY="troque-por-uma-chave-aleatoria"

# Duração do cookie de atribuição (vai para o bundle do navegador).
# Deve casar com a duração configurada em Admin › Comissões.
NEXT_PUBLIC_ATTRIBUTION_COOKIE_DAYS="30"

# URL pública do próprio site (usada em metadata/OG).
SITE_URL="http://localhost:3000"
