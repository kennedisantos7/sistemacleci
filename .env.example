# ==========================================================================
# Cleci Monorepo - variáveis de ambiente (copie para .env e preencha)
# ==========================================================================

# ---- Banco de dados (PostgreSQL no Coolify) ----
# DATABASE_URL passa pelo PgBouncer (pool). DIRECT_URL é a conexão direta,
# usada pelo Prisma apenas para migrations.
# Local (docker-compose): PgBouncer na 6432, conexão direta na 5432.
DATABASE_URL="postgresql://cleci:cleci@localhost:6432/cleci?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://cleci:cleci@localhost:5432/cleci?schema=public"

# ---- Auth.js / NextAuth ----
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-forte"
NEXTAUTH_URL="http://localhost:3001"

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- Atribuição de afiliados ----
# Duração do cookie de atribuição em dias (30 | 60 | 90)
ATTRIBUTION_COOKIE_DAYS="30"

# ---- URLs dos apps ----
SITE_URL="http://localhost:3000"
SISTEMA_URL="http://localhost:3001"

# ---- Segurança da ingestão de vendas (site -> sistema) ----
# Chave compartilhada para autenticar o POST /api/sales/ingest
INGEST_API_KEY="troque-por-uma-chave-aleatoria"

# ---- Seed do admin inicial ----
SEED_ADMIN_EMAIL="admin@clecipersonalizados.com.br"
SEED_ADMIN_PASSWORD="troque-no-primeiro-acesso"
