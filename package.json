{
  "name": "cleci-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @cleci/db generate",
    "db:migrate": "pnpm --filter @cleci/db migrate",
    "db:seed": "pnpm --filter @cleci/db seed",
    "db:studio": "pnpm --filter @cleci/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@auth/core": "0.37.2"
    }
  }
}
